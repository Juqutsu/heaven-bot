{
  "name": "heaven-bot",
  "version": "1.0.0",
  "description": "Discord bot for lost heaven",
  "main": "src/bot.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Juqutsu/heaven-bot.git"
  },
  "keywords": [
    "discord",
    "bot",
    "heaven"
  ],
  "author": "Juqutsu | Lukas",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/Juqutsu/heaven-bot/issues"
  },
  "homepage": "https://github.com/Juqutsu/heaven-bot#readme",
  "dependencies": {
    "better-sqlite3": "^9.2.2",
    "canvas": "^3.1.0",
    "discord.js": "^14.14.1",
    "dotenv": "^16.3.1",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "prettier": "^3.2.5"
  },
  "scripts": {
    "start": "node src/bot.js",
    "dev": "nodemon src/bot.js",
    "deploy": "node src/utils/deployCommands.js",
    "migrate": "node src/utils/migrate-json-to-sqlite.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/**/*.js",
    "lint:fix": "eslint src/**/*.js --fix",
    "format": "prettier --write \"src/**/*.js\"",
    "format:check": "prettier --check \"src/**/*.js\""
  }
}
