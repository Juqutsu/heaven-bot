# ============================================
# Heaven Bot - Environment Variables
# ============================================
# Copy this file to .env and fill in your values
# DO NOT commit .env to version control!

# ============================================
# REQUIRED - Bot Configuration
# ============================================

# Discord Bot Token
# Get this from: https://discord.com/developers/applications
# Navigate to your bot application > Bot > Token > Reset Token
TOKEN=

# Discord Application Client ID
# Get this from: https://discord.com/developers/applications
# Navigate to your bot application > General Information > Application ID
CLIENT_ID=

# Discord Server/Guild ID
# Right-click your Discord server > Server Settings > Widget > Server ID
# Or enable Developer Mode and right-click the server > Copy Server ID
SERVER_ID=

# ============================================
# OPTIONAL - Bot Features
# ============================================

# Bug Reports Channel ID (Optional)
# The channel where bug reports will be sent
# Can be set via /set-bug-channel command or here
# Right-click the channel > Copy Channel ID (Developer Mode required)
BUGS_CHANNEL_ID=

# ============================================
# OPTIONAL - Development & Logging
# ============================================

# Node Environment
# Set to 'development' for development mode, 'production' for production
# In development mode, console logging is enabled by default
NODE_ENV=development

# Log Level
# Options: error, warn, info, verbose, debug, silly
# Default: 'info' (or 'debug' in development mode)
LOG_LEVEL=info

# Enable Console Logging
# Set to 'true' to enable console logging even in production
# Default: enabled in development, disabled in production
LOG_CONSOLE=
